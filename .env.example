# Optional. Gemini / Veo calls use this when the in-app Gemini API Key is empty.
GEMINI_API_KEY=""

# Optional. Local Seedance bridge settings.
SEEDANCE_BRIDGE_PORT=3210
SEEDANCE_CLI_BIN="dreamina"
VITE_SEEDANCE_BRIDGE_TARGET="http://127.0.0.1:3210"

# Optional. Runtime state for the local bridge. Keep this out of Git.
RENREN_APP_DATA_DIR="./local_data"
